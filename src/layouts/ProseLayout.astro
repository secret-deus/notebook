---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import type { NoteEntry, PostEntry } from '../lib/content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import DenseEntryList from '../components/DenseEntryList.astro';
import { getPublishedNotes, getPublishedPosts, getTagMap } from '../lib/content';

interface Props {
	title: string;
	description?: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	tags?: string[];
	kind?: 'post' | 'note';
	/** 当前条目 id，用于排除自身 */
	currentId?: string;
	related?: Array<PostEntry | NoteEntry>;
}

const {
	title,
	description = '',
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	kind = 'post',
	currentId,
	related,
} = Astro.props;

const [posts, notes, tagMap] = await Promise.all([
	getPublishedPosts(),
	getPublishedNotes(),
	getTagMap(),
]);

const pool = kind === 'post' ? posts : notes;
const others = pool.filter((e) => e.id !== currentId);

const relatedResolved =
	related ??
	(() => {
		if (!tags.length) return others.slice(0, 6);
		const scored = others
			.map((e) => {
				const et = new Set(e.data.tags ?? []);
				const score = tags.reduce((n, t) => n + (et.has(t) ? 1 : 0), 0);
				return { e, score };
			})
			.filter((x) => x.score > 0)
			.sort((a, b) => b.score - a.score)
			.map((x) => x.e);
		return (scored.length ? scored : others).slice(0, 6);
	})();

const otherKindList = (kind === 'post' ? notes : posts).slice(0, 6);
const topTags = [...tagMap.entries()]
	.sort((a, b) => b[1].length - a[1].length)
	.slice(0, 8);
---

<BaseLayout title={title} description={description} wide>
	<div class="prose-board">
		<article class="article">
			{
				heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)
			}
			<header class="article-head">
				<p class="kind meta">{kind === 'post' ? '文章' : '笔记'}</p>
				<h1>{title}</h1>
				{
					(pubDate || updatedDate) && (
						<p class="meta">
							{pubDate && <FormattedDate date={pubDate} />}
							{updatedDate && (
								<>
									{pubDate ? ' · ' : ''}
									更新于 <FormattedDate date={updatedDate} />
								</>
							)}
						</p>
					)
				}
				{
					tags.length > 0 && (
						<div class="tag-row">
							{tags.map((tag) => (
								<a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
									#{tag}
								</a>
							))}
						</div>
					)
				}
			</header>
			<div class="prose">
				<slot />
			</div>
		</article>

		<aside class="board-side">
			<section class="panel">
				<div class="panel-head">
					<h2>本页</h2>
				</div>
				<ul class="bullet-list">
					<li>类型：{kind === 'post' ? '文章' : '笔记'}</li>
					{pubDate && (
						<li>
							发布：
							<FormattedDate date={pubDate} />
						</li>
					)}
					{updatedDate && (
						<li>
							更新：
							<FormattedDate date={updatedDate} />
						</li>
					)}
					<li>
						返回
						<a href={kind === 'post' ? '/posts/' : '/notes/'}>
							{kind === 'post' ? '文章列表' : '笔记列表'}
						</a>
					</li>
				</ul>
			</section>

			{
				tags.length > 0 && (
					<section class="panel">
						<div class="panel-head">
							<h2>标签</h2>
						</div>
						<div class="tag-cloud">
							{tags.map((tag) => (
								<a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
									#{tag}
								</a>
							))}
						</div>
					</section>
				)
			}

			<section class="panel">
				<div class="panel-head">
					<h2>{kind === 'post' ? '相关文章' : '相关笔记'}</h2>
					<a href={kind === 'post' ? '/posts/' : '/notes/'}>全部 →</a>
				</div>
				<DenseEntryList entries={relatedResolved} empty="暂无相关内容" showKind={false} />
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>{kind === 'post' ? '最近笔记' : '最近文章'}</h2>
					<a href={kind === 'post' ? '/notes/' : '/posts/'}>全部 →</a>
				</div>
				<DenseEntryList entries={otherKindList} empty="暂无" showKind={false} />
			</section>

			{
				topTags.length > 0 && (
					<section class="panel">
						<div class="panel-head">
							<h2>热门标签</h2>
							<a href="/tags/">全部 →</a>
						</div>
						<div class="tag-cloud">
							{topTags.map(([tag, items]) => (
								<a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
									#{tag}
									<span class="count">{items.length}</span>
								</a>
							))}
						</div>
					</section>
				)
			}
		</aside>
	</div>
</BaseLayout>

<style>
	.article-head {
		margin-bottom: 1.4rem;
		padding-bottom: 0.95rem;
		border-bottom: 1px solid rgb(var(--line));
		animation: fade-up var(--dur-slow) var(--ease-out) both;
	}
	.article-head h1 {
		margin-bottom: 0.35em;
	}
	.kind {
		margin: 0 0 0.4rem;
		letter-spacing: 0.04em;
		font-size: 0.8em;
	}
	.hero-image {
		margin: 0 0 1.1rem;
		animation: soft-scale var(--dur-slow) var(--ease-out) both;
	}
	.hero-image :global(img) {
		width: 100%;
		display: block;
		box-shadow: var(--shadow);
	}
	.prose {
		animation: fade-up var(--dur-slow) var(--ease-out) 80ms both;
	}
	.prose :global(> *:first-child) {
		margin-top: 0;
	}
</style>
