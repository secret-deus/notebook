---
import BaseLayout from '../layouts/BaseLayout.astro';
import DenseEntryList from '../components/DenseEntryList.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { entryHref, entryTitle, getPublishedPosts, getTagMap } from '../lib/content';
import { buildTagStats, tagHref } from '../lib/tags';
import { folderHref, getTopFolders } from '../lib/tree';

const posts = await getPublishedPosts();
const topFolders = getTopFolders(posts);
const recent = posts.slice(0, 14);
const hotTags = buildTagStats(posts, { minCount: 2 }).slice(0, 18);
const totalTags = (await getTagMap()).size;
const featured = posts[0] ?? null;

const latestDate = (() => {
	const dates = posts
		.map((p) => p.data.updatedDate ?? p.data.pubDate)
		.filter((d): d is Date => d instanceof Date && d.valueOf() > 0);
	if (!dates.length) return null;
	return dates.sort((a, b) => b.valueOf() - a.valueOf())[0];
})();
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} wide>
	<div class="page-board with-left home-board">
		<aside class="board-left">
			<section class="panel profile">
				<p class="eyebrow">Notebook</p>
				<h1 class="site-name">{SITE_TITLE}</h1>
				<p class="bio">{SITE_DESCRIPTION}</p>
				<p class="author meta">
					{SITE_AUTHOR}
					{
						latestDate && (
							<>
								{' '}
								· 更新 <FormattedDate date={latestDate} />
							</>
						)
					}
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href="/posts/">全部文章</a>
					<a class="btn btn-ghost" href="/tags/">标签索引</a>
				</div>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>内容概况</h2>
				</div>
				<div class="metric-grid">
					<a class="metric linkish" href="/posts/">
						<strong>{posts.length}</strong>
						<span>文章</span>
					</a>
					<a class="metric linkish" href="/tags/">
						<strong>{totalTags}</strong>
						<span>标签</span>
					</a>
					<div class="metric">
						<strong>{topFolders.length}</strong>
						<span>目录</span>
					</div>
				</div>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>快捷入口</h2>
				</div>
				<nav class="quick-nav">
					<a href="/posts/"><span>文章目录</span><em>{posts.length}</em></a>
					<a href="/tags/"><span>标签索引</span><em>{totalTags}</em></a>
					<a href="/about/"><span>关于</span><em>→</em></a>
					<a href="/rss.xml"><span>RSS</span><em>xml</em></a>
				</nav>
			</section>
		</aside>

		<div class="board-main">
			{
				featured && (
					<section class="panel featured-panel">
						<a class="featured" href={entryHref(featured)}>
							<div class="featured-top">
								<span class="pill">最新文章</span>
								{(featured.data.updatedDate ||
									(featured.data.pubDate && featured.data.pubDate.valueOf() > 0)) && (
									<span class="meta">
										<FormattedDate
											date={
												(featured.data.updatedDate ?? featured.data.pubDate) as Date
											}
										/>
									</span>
								)}
							</div>
							<h2>{entryTitle(featured)}</h2>
							{featured.data.description && <p>{featured.data.description}</p>}
							<span class="path meta">{featured.id}</span>
							<span class="read-more">阅读全文 →</span>
						</a>
					</section>
				)
			}

			{
				topFolders.length > 0 && (
					<section class="panel">
						<div class="panel-head">
							<h2>目录</h2>
							<a href="/posts/">全部 →</a>
						</div>
						<ul class="folder-cards">
							{topFolders.map((f) => (
								<li>
									<a class="folder-card" href={folderHref(f.path)}>
										<span class="folder-card-name">📁 {f.name}</span>
										<span class="folder-card-count">{f.count}</span>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}

			<section class="panel">
				<div class="panel-head">
					<h2>文章流</h2>
					<a href="/posts/">目录浏览 →</a>
				</div>
				<DenseEntryList entries={recent} empty="暂无文章，请先 npm run sync:nutstore:webdav" />
			</section>
		</div>

		<aside class="board-side">
			{
				hotTags.length > 0 && (
					<section class="panel">
						<div class="panel-head">
							<h2>热门标签</h2>
							<a href="/tags/">索引 →</a>
						</div>
						<div class="tag-cloud">
							{hotTags.map((t) => (
								<a class="tag" href={tagHref(t.tag)}>
									#{t.tag}
									<span class="count">{t.count}</span>
								</a>
							))}
						</div>
					</section>
				)
			}

			<section class="panel">
				<div class="panel-head">
					<h2>说明</h2>
				</div>
				<ul class="bullet-list">
					<li>只有<strong>文章流</strong>，不再分笔记/文章</li>
					<li>KnowledgeBase 经 WebDAV 同步后当文章发布</li>
					<li>私密内容：frontmatter <code>publish: false</code></li>
				</ul>
			</section>
		</aside>
	</div>
</BaseLayout>

<style>
	.home-board {
		padding-top: 0.25rem;
	}
	.eyebrow {
		margin: 0 0 0.35rem;
		color: var(--accent);
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
	}
	.site-name {
		margin: 0 0 0.45rem;
		font-size: 1.45rem;
	}
	.bio {
		margin: 0 0 0.7rem;
		color: rgb(var(--muted));
		font-size: 0.9rem;
	}
	.author {
		margin: 0 0 0.9rem;
	}
	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}
	.btn {
		display: inline-flex;
		padding: 0.42rem 0.85rem;
		border-radius: 999px;
		font-size: 0.84rem;
		font-weight: 600;
		text-decoration: none;
	}
	.btn-primary {
		background: var(--accent);
		color: #fff;
		border: 1px solid var(--accent);
	}
	.btn-ghost {
		border: 1px solid rgb(var(--line));
		color: rgb(var(--ink));
	}
	.metric.linkish {
		text-decoration: none;
		color: inherit;
		display: block;
	}
	.featured-panel {
		padding: 0;
		overflow: hidden;
	}
	.featured {
		display: block;
		padding: 1.1rem 1.15rem;
		text-decoration: none;
		color: inherit;
		background:
			radial-gradient(ellipse 90% 80% at 100% 0%, var(--accent-soft), transparent 55%),
			rgb(var(--surface-elevated));
	}
	.featured-top {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}
	.pill {
		padding: 0.12em 0.55em;
		border-radius: 999px;
		background: var(--accent);
		color: #fff;
		font-size: 0.72rem;
		font-weight: 700;
	}
	.featured h2 {
		margin: 0 0 0.4rem;
		font-size: 1.2rem;
	}
	.featured p {
		margin: 0 0 0.5rem;
		color: rgb(var(--muted));
		font-size: 0.9rem;
	}
	.featured .path {
		display: block;
		margin-bottom: 0.55rem;
		font-size: 0.78rem;
		word-break: break-all;
	}
	.read-more {
		color: var(--accent);
		font-weight: 600;
		font-size: 0.88rem;
	}
	.folder-cards {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
		gap: 0.5rem;
	}
	.folder-card {
		display: flex;
		justify-content: space-between;
		gap: 0.4rem;
		padding: 0.6rem 0.7rem;
		border: 1px solid rgb(var(--line));
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		background: rgb(var(--code-bg));
	}
	.folder-card:hover {
		border-color: var(--accent);
		color: inherit;
	}
	.folder-card-name {
		font-weight: 600;
		font-size: 0.88rem;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.folder-card-count {
		font-size: 0.75rem;
		color: rgb(var(--muted));
	}
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.tag-cloud .count {
		margin-left: 0.2em;
		opacity: 0.7;
	}
	@media (prefers-color-scheme: dark) {
		.pill,
		.btn-primary {
			color: #0b1a16;
		}
	}
</style>
