---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteAside from '../../components/SiteAside.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../lib/content';
import { buildTagStats, groupTagsByInitial, tagHref } from '../../lib/tags';

const posts = await getPublishedPosts();
const allStats = buildTagStats(posts, { minCount: 1 });
const hotStats = buildTagStats(posts, { minCount: 2 });
const groups = groupTagsByInitial(allStats);
---

<BaseLayout title={`标签 · ${SITE_TITLE}`} description="按标签浏览文章" wide>
	<div class="page-board">
		<div class="board-main">
			<section class="panel page-title-block">
				<h1>标签索引</h1>
				<p class="lede">
					共 <strong>{allStats.length}</strong> 个标签 · 覆盖
					<strong>{posts.length}</strong> 篇文章。
				</p>
				<input
					type="search"
					id="tag-filter"
					class="tag-filter"
					placeholder="筛选标签…"
					autocomplete="off"
				/>
			</section>

			{
				hotStats.length > 0 && (
					<section class="panel">
						<div class="panel-head">
							<h2>常用标签</h2>
							<span class="meta">≥2 篇</span>
						</div>
						<div class="tag-cloud hot" id="tag-hot">
							{hotStats.slice(0, 48).map((t) => (
								<a
									class="tag"
									href={tagHref(t.tag)}
									data-tag={t.tag.toLowerCase()}
									style={`font-size: ${0.78 + Math.min(t.count, 12) * 0.04}rem`}
								>
									#{t.tag}
									<span class="count">{t.count}</span>
								</a>
							))}
						</div>
					</section>
				)
			}

			<section class="panel">
				<div class="panel-head">
					<h2>全部标签</h2>
					<span class="meta" id="tag-visible-count">{allStats.length} 个</span>
				</div>
				<div class="tag-groups" id="tag-groups">
					{
						groups.map((g) => (
							<section class="tag-group" data-group={g.key}>
								<h3 class="group-key">{g.key}</h3>
								<ul class="tag-table">
									{g.tags.map((t) => (
										<li data-tag={t.tag.toLowerCase()}>
											<a class="tag-row-item" href={tagHref(t.tag)}>
												<span class="tag-name">#{t.tag}</span>
												<span class="tag-count">{t.count}</span>
												<span class="tag-preview meta">
													{t.entries
														.slice(0, 2)
														.map((e) => e.data.title || e.id.split('/').pop())
														.join(' · ')}
												</span>
											</a>
										</li>
									))}
								</ul>
							</section>
						))
					}
				</div>
			</section>
		</div>

		<SiteAside active="tags" listTitle="最近文章" listHref="/posts/" listEntries={posts.slice(0, 8)} />
	</div>
</BaseLayout>

<script>
	const input = document.getElementById('tag-filter') as HTMLInputElement | null;
	const groups = document.getElementById('tag-groups');
	const hot = document.getElementById('tag-hot');
	const counter = document.getElementById('tag-visible-count');

	function applyFilter() {
		const q = (input?.value || '').trim().toLowerCase();
		let visible = 0;
		groups?.querySelectorAll('li[data-tag]').forEach((li) => {
			const tag = li.getAttribute('data-tag') || '';
			const show = !q || tag.includes(q);
			(li as HTMLElement).style.display = show ? '' : 'none';
			if (show) visible++;
		});
		groups?.querySelectorAll('.tag-group').forEach((sec) => {
			const any = [...sec.querySelectorAll('li')].some(
				(li) => (li as HTMLElement).style.display !== 'none',
			);
			(sec as HTMLElement).style.display = any ? '' : 'none';
		});
		hot?.querySelectorAll('a[data-tag]').forEach((a) => {
			const tag = a.getAttribute('data-tag') || '';
			(a as HTMLElement).style.display = !q || tag.includes(q) ? '' : 'none';
		});
		if (counter) counter.textContent = `${visible} 个`;
	}
	input?.addEventListener('input', applyFilter);
</script>

<style>
	.tag-filter {
		width: 100%;
		margin-top: 0.85rem;
		padding: 0.55rem 0.75rem;
		border: 1px solid rgb(var(--line));
		border-radius: 8px;
		background: rgb(var(--surface));
		color: rgb(var(--ink));
		font: inherit;
	}
	.tag-cloud.hot {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}
	.tag-cloud .count {
		margin-left: 0.25em;
		opacity: 0.7;
		font-size: 0.85em;
	}
	.tag-groups {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
	}
	.group-key {
		margin: 0 0 0.4rem;
		font-size: 0.85rem;
		color: rgb(var(--muted));
	}
	.tag-table {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.tag-table > li + li {
		border-top: 1px solid rgb(var(--line));
	}
	.tag-row-item {
		display: grid;
		grid-template-columns: minmax(6rem, 11rem) 2.5rem minmax(0, 1fr);
		gap: 0.55rem;
		padding: 0.55rem 0.2rem;
		text-decoration: none;
		color: inherit;
		border-radius: 6px;
	}
	.tag-row-item:hover {
		background: var(--accent-soft);
		color: inherit;
	}
	.tag-name {
		font-weight: 700;
		color: var(--accent-dark);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.tag-count {
		font-size: 0.8rem;
		color: rgb(var(--muted));
	}
	.tag-preview {
		font-size: 0.8rem;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>
