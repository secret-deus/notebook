---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DenseEntryList from '../../components/DenseEntryList.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../lib/content';
import { buildTagStats, normalizeTag, tagHref } from '../../lib/tags';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const stats = buildTagStats(posts, { minCount: 1 });
	return stats.map((t) => ({
		params: { tag: t.tag },
		props: { tag: t.tag, entries: t.entries },
	}));
}

const { tag, entries } = Astro.props;
const posts = await getPublishedPosts();
const otherTags = buildTagStats(posts, { minCount: 2 })
	.filter((t) => normalizeTag(t.tag).toLowerCase() !== normalizeTag(tag).toLowerCase())
	.slice(0, 12);
---

<BaseLayout title={`#${tag} · ${SITE_TITLE}`} description={`标签：${tag}`} wide>
	<div class="page-board">
		<div class="board-main">
			<section class="panel page-title-block">
				<p class="meta"><a href="/tags/">← 全部标签</a></p>
				<h1>#{tag}</h1>
				<p class="lede">
					共 <strong>{entries.length}</strong> 篇文章
				</p>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>文章</h2>
					<span class="meta">{entries.length}</span>
				</div>
				<DenseEntryList entries={entries} showKind={false} empty="该标签下暂无内容" />
			</section>
		</div>

		<aside class="board-side">
			<section class="panel">
				<div class="panel-head">
					<h2>相关标签</h2>
					<a href="/tags/">全部 →</a>
				</div>
				<div class="tag-cloud">
					{
						otherTags.map((t) => (
							<a class="tag" href={tagHref(t.tag)}>
								#{t.tag}
								<span class="count">{t.count}</span>
							</a>
						))
					}
				</div>
			</section>
			<section class="panel">
				<div class="panel-head">
					<h2>快捷入口</h2>
				</div>
				<nav class="quick-nav">
					<a href="/posts/"><span>文章</span><em>{posts.length}</em></a>
					<a href="/tags/"><span>标签</span><em>→</em></a>
					<a href="/"><span>首页</span><em>⌂</em></a>
				</nav>
			</section>
		</aside>
	</div>
</BaseLayout>
