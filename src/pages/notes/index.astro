---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DenseEntryList from '../../components/DenseEntryList.astro';
import SiteAside from '../../components/SiteAside.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedNotes, getPublishedPosts } from '../../lib/content';

const notes = await getPublishedNotes();
const posts = await getPublishedPosts();
---

<BaseLayout title={`笔记 · ${SITE_TITLE}`} description="来自 Obsidian 的常青笔记" wide>
	<div class="page-board">
		<div class="board-main">
			<section class="panel page-title-block">
				<h1>笔记</h1>
				<p class="lede">
					常青笔记，支持 <code>[[双链]]</code>。共 <strong>{notes.length}</strong> 篇。可用
					<code>npm run sync:vault</code> 从 Obsidian 同步。
				</p>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>全部笔记</h2>
					<span class="meta">{notes.length} 篇</span>
				</div>
				<DenseEntryList
					entries={notes}
					empty="还没有笔记。运行 npm run sync:vault 或手动添加 Markdown。"
					showKind={false}
				/>
			</section>
		</div>

		<SiteAside
			active="notes"
			listTitle="最近文章"
			listHref="/posts/"
			listEntries={posts}
			listEmpty="暂无文章"
			showKind={false}
			tipsTitle="同步提示"
			tips={[
				'公开笔记加 <code>publish: true</code>',
				'私密笔记 <code>publish: false</code> 或放 private/',
				'文件名尽量与 <code>[[双链]]</code> 目标一致',
			]}
		/>
	</div>
</BaseLayout>
