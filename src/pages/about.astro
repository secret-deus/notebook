---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteAside from '../components/SiteAside.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPublishedPosts } from '../lib/content';

const posts = await getPublishedPosts();
---

<BaseLayout title={`关于 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} wide>
	<div class="page-board">
		<div class="board-main">
			<section class="panel page-title-block">
				<h1>关于</h1>
				<p class="lede">{SITE_DESCRIPTION}</p>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>这个站</h2>
				</div>
				<p>
					<strong>{SITE_AUTHOR}</strong> 的笔记博客：在 Obsidian / 坚果云写，用 Astro 发布为<strong
						>统一文章流</strong
					>。
				</p>
				<p class="meta">当前已发布文章 {posts.length} 篇。</p>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>内容从哪来</h2>
				</div>
				<ul class="bullet-list">
					<li>坚果云 <code>KnowledgeBase</code> 经 WebDAV 同步</li>
					<li>写入 <code>src/content/posts/</code>，全部按文章发布</li>
					<li>保留原文件夹结构，可在「文章」页按目录浏览</li>
				</ul>
			</section>

			<section class="panel">
				<div class="panel-head">
					<h2>同步命令</h2>
				</div>
				<ol class="bullet-list numbered">
					<li>配置 <code>.env</code> 中的坚果云 WebDAV</li>
					<li><code>npm run sync:nutstore:webdav</code></li>
					<li><code>npm run dev</code> 预览 / <code>npm run build</code> 构建</li>
				</ol>
			</section>
		</div>

		<SiteAside active="about" />
	</div>
</BaseLayout>

<style>
	.numbered {
		list-style: decimal;
		padding-left: 1.25rem;
	}
	.board-main p {
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
	}
</style>
