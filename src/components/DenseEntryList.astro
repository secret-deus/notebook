---
import type { PostEntry } from '../lib/content';
import { entryHref, entryTitle } from '../lib/content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	entries: PostEntry[];
	empty?: string;
	showKind?: boolean;
	clamp?: number;
}

const { entries, empty = '暂无内容', showKind = false, clamp } = Astro.props;
const list = typeof clamp === 'number' ? entries.slice(0, clamp) : entries;
---

{
	list.length === 0 ? (
		<p class="empty-hint">{empty}</p>
	) : (
		<ul class="dense-list">
			{list.map((entry) => {
				const date = entry.data.updatedDate ?? entry.data.pubDate;
				const desc = entry.data.description;
				const tags = entry.data.tags ?? [];
				const showDate = date && date.valueOf() > 0;
				return (
					<li>
						<a class="dense-item" href={entryHref(entry)}>
							<div class="dense-main">
								<span class="dense-title">
									{showKind && <span class="kind-dot" title="文章" />}
									{entryTitle(entry)}
								</span>
								{desc && <span class="dense-desc">{desc}</span>}
								<span class="dense-path meta">{entry.id}</span>
							</div>
							<div class="dense-meta">
								{showDate && <FormattedDate date={date} />}
								{tags[0] && <span class="dense-tag">#{tags[0]}</span>}
							</div>
						</a>
					</li>
				);
			})}
		</ul>
	)
}

<style>
	.dense-path {
		font-size: 0.72rem;
		opacity: 0.75;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>
