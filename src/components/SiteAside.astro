---
/**
 * 全站通用侧栏：快捷入口 + 统计 + 标签 + 最近文章
 */
import type { PostEntry } from '../lib/content';
import { getPublishedPosts, getTagMap } from '../lib/content';
import { tagHref } from '../lib/tags';
import DenseEntryList from './DenseEntryList.astro';

interface Props {
	active?: 'home' | 'posts' | 'notes' | 'tags' | 'about';
	listTitle?: string;
	listHref?: string;
	listEntries?: PostEntry[];
	listEmpty?: string;
	showKind?: boolean;
	tips?: string[];
	tipsTitle?: string;
}

const {
	active,
	listTitle = '最近文章',
	listHref = '/posts/',
	listEntries,
	listEmpty = '暂无内容',
	showKind = false,
	tips,
	tipsTitle = '说明',
} = Astro.props;

const posts = await getPublishedPosts();
const tagMap = await getTagMap();

const tags = [...tagMap.entries()]
	.sort((a, b) => b[1].length - a[1].length)
	.slice(0, 10);

const fallbackList = listEntries ?? posts.slice(0, 8);
---

<aside class="board-side">
	<section class="panel">
		<div class="panel-head">
			<h2>快捷入口</h2>
		</div>
		<nav class="quick-nav" aria-label="站内导航">
			<a href="/" class:list={[{ active: active === 'home' }]}>
				<span>首页</span><em>⌂</em>
			</a>
			<a href="/posts/" class:list={[{ active: active === 'posts' || active === 'notes' }]}>
				<span>文章</span><em>{posts.length}</em>
			</a>
			<a href="/tags/" class:list={[{ active: active === 'tags' }]}>
				<span>标签</span><em>{tagMap.size}</em>
			</a>
			<a href="/about/" class:list={[{ active: active === 'about' }]}>
				<span>关于</span><em>→</em>
			</a>
			<a href="/rss.xml">
				<span>RSS</span><em>xml</em>
			</a>
		</nav>
	</section>

	<section class="panel">
		<div class="panel-head">
			<h2>内容概况</h2>
		</div>
		<div class="metric-grid">
			<div class="metric">
				<strong>{posts.length}</strong>
				<span>文章</span>
			</div>
			<div class="metric">
				<strong>{tagMap.size}</strong>
				<span>标签</span>
			</div>
		</div>
	</section>

	<section class="panel">
		<div class="panel-head">
			<h2>{listTitle}</h2>
			{listHref && <a href={listHref}>全部 →</a>}
		</div>
		<DenseEntryList entries={fallbackList} empty={listEmpty} showKind={showKind} />
	</section>

	{
		tags.length > 0 && (
			<section class="panel">
				<div class="panel-head">
					<h2>热门标签</h2>
					<a href="/tags/">全部 →</a>
				</div>
				<div class="tag-cloud">
					{tags.map(([tag, items]) => (
						<a class="tag" href={tagHref(tag)}>
							#{tag}
							<span class="count">{items.length}</span>
						</a>
					))}
				</div>
			</section>
		)
	}

	{
		tips && tips.length > 0 && (
			<section class="panel">
				<div class="panel-head">
					<h2>{tipsTitle}</h2>
				</div>
				<ul class="bullet-list">
					{tips.map((t) => (
						<li set:html={t} />
					))}
				</ul>
			</section>
		)
	}
</aside>
